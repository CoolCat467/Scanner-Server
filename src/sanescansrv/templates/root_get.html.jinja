{% extends "base.html.jinja" %}
{% block title %}Request Scan{% endblock title %}
{% block body %}
<b>Press Scan to start scanning.</b>
<form name="scan_request" method="post">
  <div class="box">
    <span>Select Image format:</span>
    <br>
    <br>
    <input type="radio" id="img_format_0" name="img_format" value="png">
    <label for="img_format_0">PNG</label>
    <br>
    <input type="radio" id="img_format_1" name="img_format" value="jpeg" checked="checked">
    <label for="img_format_1">JPEG</label>
    <br>
    <input type="radio" id="img_format_2" name="img_format" value="pnm">
    <label for="img_format_2">PNM</label>
    <br>
    <input type="radio" id="img_format_3" name="img_format" value="tiff">
    <label for="img_format_3">TIFF</label>
    <br>
  </div>
  <div class="box">
    <span>Select a Scanner:</span>
    <br>
    {% for scanner in scanners %}
    <input {% if scanner.device_name == default %}checked="checked" {% endif %}{% if not scanner.active %}disabled="disabled" {% endif %}type="radio" id="scanner_{{ loop.index0 }}" name="scanner" value="{{ scanner.device_name|escape }}">
    <label for="scanner_{{ loop.index0 }}">{{ scanner.vendor|escape }} {{ scanner.model|escape }} (<i>{{ scanner.type_|escape }}</i>)</label>
    <br>
    {% else %}
    <input type="radio" id="scanner_0" name="scanner" value="none" checked="checked">
    <label for="scanner_0">None - <a href="/update_scanners">Update Devices</a></label>
    <br>
    {% endfor %}
  </div>
  <br>
  <input type="submit" id="scan_request_submit_button" name="scan_request_submit_button" value="Scan!">
</form>
<hr>
<a href="/update_scanners"><button>Update Devices</button></a>
<a href="/scanners"><button>Scanner Settings</button></a>
{% endblock body %}
